generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum Role {
  ADMIN
  PROFESSOR
  GRAD
  CONTRIBUTOR
  USER
}

enum VoteTargetType {
  POST
  COMMENT
}

enum VoteValue {
  UP
  DOWN
}

enum RoleRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ✅ 알림 채널 (RSS 자체는 저장 필요 없지만, 메일/문자 알림은 필요)
enum NotifyChannel {
  EMAIL
  SMS
}

//////////////////////////////////////////////////
// NextAuth models (기존 유지 + relations 추가)
//////////////////////////////////////////////////

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  posts    Post[]
  comments Comment[]
  votes    Vote[]

  profile UserProfile?

  createdAt DateTime @default(now())

  roleRequests         RoleRequest[] @relation("RoleRequestRequester")
  reviewedRoleRequests RoleRequest[] @relation("RoleRequestReviewer")

  subscriptions Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//////////////////////////////////////////////////
// User Profile (필명 + 등급)
//////////////////////////////////////////////////

model UserProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String @unique
  role        Role   @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

//////////////////////////////////////////////////
// Posts (기존 유지 + votes/comments + attachments 연결)
//////////////////////////////////////////////////

model Post {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String
  category  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  views Int @default(0)

  comments Comment[]
  votes    Vote[]    @relation("PostVotes")

  attachments Attachment[]
  notificationJobs NotificationJob[]

  @@map("posts")
}

//////////////////////////////////////////////////
// Attachments (Post 첨부파일)
//////////////////////////////////////////////////

model Attachment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  url       String
  fileName  String   @map("file_name")
  mimeType  String   @default("application/octet-stream") @map("mime_type")
  size      Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([postId])
  @@map("attachments")
}

//////////////////////////////////////////////////
// Comments
//////////////////////////////////////////////////

model Comment {
  id     String @id @default(uuid()) @db.Uuid
  postId String @map("post_id") @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  parentId String?   @map("parent_id") @db.Uuid
  parent   Comment?  @relation("CommentToReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentToReplies")

  content String // TipTap HTML 저장

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  votes Vote[] @relation("CommentVotes")

  @@index([postId])
  @@map("comments")
}

//////////////////////////////////////////////////
// Votes (Post + Comment 공통)
//////////////////////////////////////////////////

model Vote {
  id String @id @default(uuid()) @db.Uuid

  postId    String? @map("post_id") @db.Uuid
  commentId String? @map("comment_id") @db.Uuid

  value VoteValue

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  post    Post?    @relation("PostVotes", fields: [postId], references: [id], onDelete: Cascade, map: "votes_post_id_fkey")
  comment Comment? @relation("CommentVotes", fields: [commentId], references: [id], onDelete: Cascade, map: "votes_comment_id_fkey")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@map("votes")
}

//////////////////////////////////////////////////
// Role requests
//////////////////////////////////////////////////

model RoleRequest {
  id     String @id @default(uuid()) @db.Uuid

  userId String @map("user_id")
  user   User   @relation("RoleRequestRequester", fields: [userId], references: [id], onDelete: Cascade)

  requestedRole Role
  status        RoleRequestStatus @default(PENDING)

  note      String?
  adminNote String? @map("admin_note")

  decidedAt DateTime? @map("decided_at")

  decidedBy String? @map("decided_by")
  reviewer  User?   @relation("RoleRequestReviewer", fields: [decidedBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([decidedBy])
  @@map("role_requests")
}

//////////////////////////////////////////////////
// Subscriptions (메일/문자 알림 구독)
//////////////////////////////////////////////////

model Subscription {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 어떤 카테고리를 구독하는지
  category  String

  // 지금은 EMAIL만
  channel   NotificationChannel @default(EMAIL)

  // 구독 on/off
  active    Boolean             @default(true)

  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, category, channel])
  @@index([category, active])
  @@map("subscriptions")
}

//////////////////////////////////////////////////
// Notification Jobs (발송 큐)
//////////////////////////////////////////////////

enum NotificationChannel {
  EMAIL
}

enum NotificationDestination {
  SUBSCRIBERS
}

model NotificationJob {
  id        String   @id @default(uuid()) @db.Uuid

  postId    String   @db.Uuid
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  category  String

  channel   NotificationChannel @default(EMAIL)
  processed Boolean             @default(false)

  createdAt DateTime            @default(now()) @map("created_at")
  processedAt DateTime?         @map("processed_at")

  @@index([processed, createdAt])
  @@index([postId])
  @@map("notification_jobs")
}