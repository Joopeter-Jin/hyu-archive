generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum Role {
  ADMIN
  PROFESSOR
  GRAD
  CONTRIBUTOR
  USER
}

enum VoteTargetType {
  POST
  COMMENT
}

enum VoteValue {
  UP
  DOWN
}

enum RoleRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotifyChannel {
  EMAIL
  SMS
}

enum ReactionType {
  LIKE
  BOOKMARK
}

enum EndorsementType {
  PROFESSOR
  GRAD
}

enum EndorsementSentiment {
  POSITIVE
  NEGATIVE
}

enum LogAction {
  POST_CREATE
  POST_UPDATE
  POST_DELETE

  REACTION_LIKE_ON
  REACTION_LIKE_OFF
  REACTION_BOOKMARK_ON
  REACTION_BOOKMARK_OFF

  CITATION_CREATE
  CITATION_DELETE

  ENDORSEMENT_CREATE
  ENDORSEMENT_DELETE

  ARCHIVE_PICK_ON
  ARCHIVE_PICK_OFF

  MERIT_BADGE_GRANT
  MERIT_BADGE_REVOKE

  POST_PIN_ON
  POST_PIN_OFF

  ROLE_REQUEST_CREATE
  ROLE_REQUEST_DECIDE

  DM_THREAD_CREATE
  DM_MESSAGE_SEND
}

//////////////////////////////////////////////////
// NextAuth models
//////////////////////////////////////////////////

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  posts    Post[]
  comments Comment[]
  votes    Vote[]

  profile UserProfile?

  createdAt DateTime @default(now())

  roleRequests         RoleRequest[] @relation("RoleRequestRequester")
  reviewedRoleRequests RoleRequest[] @relation("RoleRequestReviewer")

  subscriptions Subscription[]

  dmThreadsA DMThread[]    @relation("DMUserA")
  dmThreadsB DMThread[]    @relation("DMUserB")
  dmMessages DMMessage[]
  dmReads    DMReadState[]

  reactions         Reaction[]
  endorsementsGiven Endorsement[]    @relation("EndorsementsGiven")
  archivePicks      ArchivePick[]
  meritBadges       UserMeritBadge[]
  logsAsActor       ActivityLog[]    @relation("LogsActor")
  logsAsTarget      ActivityLog[]    @relation("LogsTargetUser")
  postPins          PostPin[]        @relation("PinsByUser")

  scoreSnapshots ScoreSnapshot[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//////////////////////////////////////////////////
// User Profile
//////////////////////////////////////////////////

model UserProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String @unique
  role        Role   @default(USER)

  contributorLevel Int @default(0) @map("contributor_level")

  score90dActivity   Int @default(0) @map("score_90d_activity")
  score90dImpact     Int @default(0) @map("score_90d_impact")
  score90dScholarly  Int @default(0) @map("score_90d_scholarly")
  score90dTotal      Int @default(0) @map("score_90d_total")

  scoreUpdatedAt DateTime? @map("score_updated_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

//////////////////////////////////////////////////
// Posts
//////////////////////////////////////////////////

model Post {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String
  category  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  views Int @default(0)

  comments Comment[]
  votes    Vote[]    @relation("PostVotes")

  attachments      Attachment[]
  notificationJobs NotificationJob[]

  reactions     Reaction[]
  citationsFrom Citation[]    @relation("CitationsFrom")
  citationsTo   Citation[]    @relation("CitationsTo")
  endorsements  Endorsement[]
  archivePick   ArchivePick?
  pins          PostPin[]

  logs ActivityLog[] @relation("LogPost")

  @@map("posts")
}

//////////////////////////////////////////////////
// Attachments
//////////////////////////////////////////////////

model Attachment {
  id String @id @default(uuid()) @db.Uuid

  postId String @map("post_id") @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  url      String
  fileName String @map("file_name")
  mimeType String @default("application/octet-stream") @map("mime_type")
  size     Int    @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([postId])
  @@map("attachments")
}

//////////////////////////////////////////////////
// Comments
//////////////////////////////////////////////////

model Comment {
  id     String @id @default(uuid()) @db.Uuid
  postId String @map("post_id") @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  parentId String?   @map("parent_id") @db.Uuid
  parent   Comment?  @relation("CommentToReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentToReplies")

  content String

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  votes Vote[] @relation("CommentVotes")

  @@index([postId])
  @@map("comments")
}

//////////////////////////////////////////////////
// Votes
//////////////////////////////////////////////////

model Vote {
  id String @id @default(uuid()) @db.Uuid

  postId    String? @map("post_id") @db.Uuid
  commentId String? @map("comment_id") @db.Uuid

  value VoteValue

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  post    Post?    @relation("PostVotes", fields: [postId], references: [id], onDelete: Cascade, map: "votes_post_id_fkey")
  comment Comment? @relation("CommentVotes", fields: [commentId], references: [id], onDelete: Cascade, map: "votes_comment_id_fkey")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@map("votes")
}

//////////////////////////////////////////////////
// Role requests
//////////////////////////////////////////////////

model RoleRequest {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id")
  user   User   @relation("RoleRequestRequester", fields: [userId], references: [id], onDelete: Cascade)

  requestedRole Role
  status        RoleRequestStatus @default(PENDING)

  note      String?
  adminNote String? @map("admin_note")

  decidedAt DateTime? @map("decided_at")

  decidedBy String? @map("decided_by")
  reviewer  User?   @relation("RoleRequestReviewer", fields: [decidedBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([decidedBy])
  @@map("role_requests")
}

//////////////////////////////////////////////////
// Subscriptions
//////////////////////////////////////////////////

model Subscription {
  id     String @id @default(uuid()) @db.Uuid
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category String
  channel  NotifyChannel @default(EMAIL)
  active   Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category, channel])
  @@index([category, active])
  @@map("subscriptions")
}

//////////////////////////////////////////////////
// Notification Jobs
//////////////////////////////////////////////////

model NotificationJob {
  id String @id @default(uuid()) @db.Uuid

  postId String @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  category  String
  channel   NotifyChannel @default(EMAIL)
  processed Boolean       @default(false)

  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  @@index([processed, createdAt])
  @@index([postId])
  @@map("notification_jobs")
}

//////////////////////////////////////////////////
// DM
//////////////////////////////////////////////////

model DMThread {
  id String @id @default(uuid()) @db.Uuid

  userAId String @map("user_a_id")
  userBId String @map("user_b_id")

  userA User @relation("DMUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("DMUserB", fields: [userBId], references: [id], onDelete: Cascade)

  messages DMMessage[]
  reads    DMReadState[]

  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([userAId, userBId])
  @@index([lastMessageAt])
  @@map("dm_threads")
}

model DMMessage {
  id String @id @default(uuid()) @db.Uuid

  threadId String   @map("thread_id") @db.Uuid
  thread   DMThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  senderId String @map("sender_id")
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  body      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([threadId, createdAt])
  @@index([senderId])
  @@map("dm_messages")
}

model DMReadState {
  id String @id @default(uuid()) @db.Uuid

  threadId String   @map("thread_id") @db.Uuid
  thread   DMThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastReadAt DateTime @default(now()) @map("last_read_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([threadId, userId])
  @@index([userId, lastReadAt])
  @@map("dm_read_states")
}

//////////////////////////////////////////////////
// Reaction
//////////////////////////////////////////////////

model Reaction {
  id String @id @default(uuid()) @db.Uuid

  postId String @map("post_id") @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type ReactionType

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, userId, type])
  @@index([userId, createdAt])
  @@index([postId, createdAt])
  @@map("reactions")
}

//////////////////////////////////////////////////
// Citation
//////////////////////////////////////////////////

model Citation {
  id String @id @default(uuid()) @db.Uuid

  fromPostId String @map("from_post_id") @db.Uuid
  toPostId   String @map("to_post_id") @db.Uuid

  fromPost Post @relation("CitationsFrom", fields: [fromPostId], references: [id], onDelete: Cascade)
  toPost   Post @relation("CitationsTo", fields: [toPostId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([fromPostId, toPostId])
  @@index([toPostId, createdAt])
  @@index([fromPostId, createdAt])
  @@map("citations")
}

//////////////////////////////////////////////////
// Endorsement
//////////////////////////////////////////////////

model Endorsement {
  id String @id @default(uuid()) @db.Uuid

  postId String @map("post_id") @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  endorserId String @map("endorser_id")
  endorser   User   @relation("EndorsementsGiven", fields: [endorserId], references: [id], onDelete: Cascade)

  type      EndorsementType
  sentiment EndorsementSentiment @default(POSITIVE)

  endorserRoleSnapshot Role    @default(USER) @map("endorser_role_snapshot")
  note                 String?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, endorserId, type])
  @@index([postId, createdAt])
  @@index([endorserId, createdAt])
  @@map("endorsements")
}

model ScoreSnapshot {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  windowDays Int @default(90) @map("window_days")
  dateKey    DateTime @map("date_key") // KST 00:00 기준으로 저장

  activity  Int @default(0)
  impact    Int @default(0)
  scholarly Int @default(0)
  total     Int @default(0)

  level Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, windowDays, dateKey])
  @@index([dateKey])
  @@index([userId, dateKey])
  @@map("score_snapshots")
}

//////////////////////////////////////////////////
// ArchivePick
//////////////////////////////////////////////////

model ArchivePick {
  id String @id @default(uuid()) @db.Uuid

  postId String @map("post_id") @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  adminId String @map("admin_id")
  admin   User   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  active Boolean @default(true)
  note   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([postId])
  @@index([adminId, createdAt])
  @@map("archive_picks")
}

//////////////////////////////////////////////////
// MeritBadge
//////////////////////////////////////////////////

model MeritBadge {
  id String @id @default(uuid()) @db.Uuid

  code        String  @unique
  name        String
  description String?

  iconKey String? @map("icon_key")
  active  Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users UserMeritBadge[]

  @@map("merit_badges")
}

model UserMeritBadge {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  badgeId String     @map("badge_id") @db.Uuid
  badge   MeritBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  grantedBy String? @map("granted_by")
  note      String?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, badgeId])
  @@index([userId, createdAt])
  @@index([badgeId, createdAt])
  @@map("user_merit_badges")
}

//////////////////////////////////////////////////
// PostPin
//////////////////////////////////////////////////

model PostPin {
  id String @id @default(uuid()) @db.Uuid

  postId String @map("post_id") @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  category String

  pinnedById String @map("pinned_by_id")
  pinnedBy   User   @relation("PinsByUser", fields: [pinnedById], references: [id], onDelete: Cascade)

  active Boolean @default(true)
  order  Int     @default(0)

  pinnedAt   DateTime  @default(now()) @map("pinned_at")
  unpinnedAt DateTime? @map("unpinned_at")

  @@unique([category, postId])
  @@index([category, active, order, pinnedAt])
  @@index([postId])
  @@map("post_pins")
}

//////////////////////////////////////////////////
// ActivityLog
//////////////////////////////////////////////////

model ActivityLog {
  id String @id @default(uuid()) @db.Uuid

  actorId String? @map("actor_id")
  actor   User?   @relation("LogsActor", fields: [actorId], references: [id], onDelete: SetNull)

  action LogAction

  postId String? @map("post_id") @db.Uuid
  post   Post?   @relation("LogPost", fields: [postId], references: [id], onDelete: SetNull)

  targetUserId String? @map("target_user_id")
  targetUser   User?   @relation("LogsTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  meta Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([postId, createdAt])
  @@index([targetUserId, createdAt])
  @@map("activity_logs")
}
